{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ASOptimus",
  "version": "0.1.0",
  "identifier": "com.asoptimus.desktop",
  "build": {
    "frontendDist": "../ui",
    "beforeBuildCommand": "bun ../src/build.ts --sidecar",
    "beforeDevCommand": "bun ../src/build.ts --sidecar"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "shortDescription": "ASO keyword research desktop app",
    "longDescription": "ASOptimus — local App Store keyword research program. Native window over the localhost UI; computation and billing happen in the cloud.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "externalBin": ["binaries/asoptimus-sidecar"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist",
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 },
        "windowSize": { "width": 660, "height": 420 }
      }
    }
  }
}
