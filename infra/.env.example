# ==============================================================================
# ASOptimus — environment template.  Copy to `.env` and fill the REPLACE_ME's:
#     cp .env.example .env
# docker compose reads this file from the infra/ directory (run compose here).
#
# Legend:
#   [prod-required]  must be a real value before you take money / run for real
#   [optional]       has a safe default; leave as-is unless you need to change it
#   [dev-mock]       if unset, the server runs an offline mock for that dependency
#
# Server env is read in server/src/**; keys marked (not-yet-wired) are consumed
# as their feature lands (SMTP email, HMAC sessions, public URLs) — set them for
# a real prod deploy so nothing is missing when that code ships.
# ==============================================================================

# ── Core ──────────────────────────────────────────────────────────────────────
# [optional] HTTP + WSS port. Compose maps ${PORT}:${PORT} and health-checks it.
PORT=8787

# ── Database ──────────────────────────────────────────────────────────────────
# These three create the bundled compose Postgres AND derive the server's
# DATABASE_URL (postgres://USER:PASSWORD@postgres:5432/DB). Keep them consistent.
# [prod-required] pick a strong password.
POSTGRES_USER=asoptimus
POSTGRES_PASSWORD=REPLACE_ME_strong_db_password
POSTGRES_DB=asoptimus
#
# [optional] DATABASE_URL — leave COMMENTED for the bundled Postgres (compose
# derives it from POSTGRES_* above). Set it ONLY when using an external/managed
# Postgres (Neon / Supabase / Fly PG) instead of the bundled service; then also
# remove the `postgres` + `migrate` services from docker-compose.yml.
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# ── Anthropic (LLM) ───────────────────────────────────────────────────────────
# [prod-required][dev-mock] MUST be an API key, NOT a subscription (D4): with a
# subscription costUsd=null → runs are billed as free. Unset → deterministic
# MockLlmClient (offline, no network).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
#
# [optional] Live per-model prices (D4 — never hardcode in the adapter). JSON map
# model -> {inputPer1M, outputPer1M} in USD; merged over built-in defaults.
# MODEL_PRICES_JSON={"claude-haiku-4-5":{"inputPer1M":1,"outputPer1M":5},"claude-sonnet-5":{"inputPer1M":3,"outputPer1M":15},"claude-opus-4-8":{"inputPer1M":5,"outputPer1M":25}}

# ── Stripe (credit top-ups) ───────────────────────────────────────────────────
# [prod-required][dev-mock] unset → mock checkout (placeholder URL; grant credits
# in dev via POST /api/dev/complete-checkout).
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
# [prod-required] signing secret of the /webhooks/stripe endpoint (idempotent grants).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Email (transactional SMTP) ── (not-yet-wired: §9 delivery of key + magic-link)
# [prod-required] use a transactional relay (Postmark/SES/Resend/etc.), not a
# self-hosted mail server, or activation mail lands in spam.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SMTP_FROM=ASOptimus <noreply@asoptimus.com>

# ── Public URLs ── (not-yet-wired: what the client program + landing point at)
# [prod-required] your API's public origin behind TLS (api.asoptimus.com).
PUBLIC_API_URL=https://api.asoptimus.com
PUBLIC_WSS_URL=wss://api.asoptimus.com/ws

# ── Session / signing secrets ── (not-yet-wired: session tokens + per-message HMAC)
# [prod-required] generate each with:  openssl rand -hex 32
JWT_SECRET=REPLACE_ME_openssl_rand_hex_32
HMAC_SECRET=REPLACE_ME_openssl_rand_hex_32

# ── Billing / signup ──────────────────────────────────────────────────────────
# [optional] free credits granted on signup (§9: only for verified email; 0 = off).
SIGNUP_FREE_CREDITS=0

# ── Apple job dispatch ────────────────────────────────────────────────────────
# [prod-required for real hosting] REQUIRE_CLIENT=1 → Apple jobs only go to a real
# connected client over WSS (fetched from the USER's IP — the whole point, D1/D3).
# Unset → dev loopback (server runs mock-apple locally; offline happy-path only).
REQUIRE_CLIENT=1
