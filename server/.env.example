# asoptimus-server — environment variables. Copy to .env and fill in the secrets.
#
# MODE: without DEV=1 the server runs in PROD — a missing required secret = hard refusal
# at startup (no silent mock). DEV=1 enables offline mocks (Memory/Mock-LLM/Mock-Stripe/
# loopback Apple, DEV-log email) for local development without secrets or network.

# ── Mode ───────────────────────────────────────────────────────────────────────
# DEV=1 — enable mocks/loopback/dev helpers. Do NOT set in prod.
# DEV=1

# ── Core ───────────────────────────────────────────────────────────────────────
PORT=8787

# ── Postgres [prod-required] ───────────────────────────────────────────────────
# Missing in prod → refusal. Missing under DEV=1 → in-memory (no persistence).
DATABASE_URL=postgres://user:pass@localhost:5432/asoptimus

# ── Anthropic (LLM) [prod-required] ────────────────────────────────────────────
# IMPORTANT (D4): API KEY, NOT a subscription — otherwise costUsd=null (internal COGS accounting lies).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# [opt] Live model token prices (internal COGS). JSON: {"<model>":{"inputPer1M":N,"outputPer1M":N}}
# MODEL_PRICES_JSON={"claude-haiku-4-5":{"inputPer1M":1,"outputPer1M":5}}

# ── Price per keyphrase (D4 v4 — THE USER'S BILL) [opt; edit HERE, not in code] ─
# Credits per verified keyphrase (1 credit = $1). Defaults are a placeholder (Haiku 0.02,
# Sonnet 0.05, Opus 0.08, Fable 0.15); final numbers are yours to set. JSON: {"<model>":N}
# PRICE_PER_KEYPHRASE_JSON={"claude-haiku-4-5":0.02,"claude-sonnet-5":0.05,"claude-opus-4-8":0.08,"claude-fable-5":0.15}

# ── Paddle (credit top-up, $1/credit; merchant of record) [prod-required] ──────
# Missing key in prod → refusal. Under DEV=1 — mock (grant via POST /api/dev/complete-checkout).
# Server-side API key (Paddle → Developer tools → Authentication → API keys).
# LIVE keys are pdl_live_…; sandbox keys are pdl_sdbx_… and need PADDLE_ENV=sandbox below.
PADDLE_API_KEY=pdl_live_REPLACE_ME
# Signing secret of the /webhooks/paddle notification destination (shown ONCE at creation;
# per environment — the sandbox secret does not verify live deliveries).
PADDLE_WEBHOOK_SECRET=pdl_ntfset_REPLACE_ME
# [opt] "sandbox" → sandbox-api.paddle.com (pair with a pdl_sdbx_ key). LEAVE UNSET for live.
# PADDLE_ENV=sandbox
# PUBLIC client-side token for the /buy page (Developer tools → Authentication → Client tokens).
# live_… for live; test_… auto-selects the sandbox environment in Paddle.js.
PADDLE_CLIENT_TOKEN=live_REPLACE_ME
# [opt] catalog price of ONE credit (enables custom top-up amounts, charged via quantity;
# the price's quantity maximum must be ≥ TOPUP_CUSTOM_MAX). Unset → packages only.
# PADDLE_CREDIT_PRICE_ID=pri_REPLACE_ME
# [opt] custom-amount bounds in credits (defaults 5 / 500).
# TOPUP_CUSTOM_MIN=5
# TOPUP_CUSTOM_MAX=500
# [opt] fallback checkout page base when the transaction carries no hosted checkout url;
# normally set the default payment link (Paddle → Checkout settings) to https://api.<domain>/buy.
# PADDLE_CHECKOUT_URL=https://api.asoptimus.com/buy
# Top-up packages — in prod every entry must carry its pri_… from the SAME Paddle environment
# as PADDLE_API_KEY. JSON: {"<id>":{"chargeUsd":N,"credits":N,"label":"...","paddlePriceId":"pri_…"}}
TOPUP_PACKAGES_JSON={"p10":{"chargeUsd":10,"credits":10,"label":"10 credits","paddlePriceId":"pri_REPLACE"},"p25":{"chargeUsd":25,"credits":26,"label":"25 credits (+1 bonus)","paddlePriceId":"pri_REPLACE"},"p50":{"chargeUsd":50,"credits":53,"label":"50 credits (+3 bonus)","paddlePriceId":"pri_REPLACE"},"p100":{"chargeUsd":100,"credits":110,"label":"100 credits (+10 bonus)","paddlePriceId":"pri_REPLACE"}}

# ── Email (transactional SMTP) [prod-required] ─────────────────────────────────
# Provider-agnostic: any transactional relay (Postmark/SES/Resend/…). Missing SMTP_HOST in
# prod → refusal (key/receipt emails must not be lost silently). Under DEV=1 — DEV-log (no sending).
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SMTP_FROM=ASOptimus <noreply@asoptimus.com>

# ── Apple job dispatch [prod] ──────────────────────────────────────────────────
# REQUIRE_CLIENT=1 — Apple jobs go only to a real client over WSS (fetch from the user's IP, D1/D3).
# In prod (DEV unset) loopback is always off. Under DEV=1 without REQUIRE_CLIENT — loopback mock-apple.
REQUIRE_CLIENT=1

# ── Client release [opt; fill in when publishing a signed macOS .dmg] ──────────
# GET /download/manifest serves this as-is. JSON: {"version":"...","platforms":{"macos-arm64":{"url":"...","sha256":"..."}}}
# CLIENT_DOWNLOAD_MANIFEST_JSON={"version":"1.0.0","platforms":{"macos-arm64":{"url":"https://.../asoptimus.dmg","sha256":"..."}}}
